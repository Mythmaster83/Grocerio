# Copy this file to `.env` in the project root and fill in real values.
# `.env` is git-ignored — never commit real keys.
#
# Get a free Pexels API key at https://www.pexels.com/api/
PEXELS_API_KEY=REPLACE_ME

# Base URL for a future backend proxy (see architecture.md — "Known
# Limitation: Client-Embedded API Keys"). Leave as-is until that proxy exists.
API_BASE_URL=REPLACE_ME
