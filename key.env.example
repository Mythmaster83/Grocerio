# Copy this file to `.env` in the project root and fill in real values.
# `.env` is git-ignored — never commit real keys.
#
# Get a free Pexels API key at https://www.pexels.com/api/
# Required only when API_BASE_URL is unset (direct client → Pexels).
PEXELS_API_KEY=REPLACE_ME

# Image proxy origin (no trailing slash). When set, the app calls
# GET {API_BASE_URL}/images/search?q=… and does not need a client Pexels key.
# Deploy: backend/image-proxy/README.md
API_BASE_URL=REPLACE_ME
